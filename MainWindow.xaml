<Window x:Class="SpotifyLyricsOverlay.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spotify Lyrics Overlay"
        Width="920"
        Height="228"
        MinWidth="440"
        MinHeight="158"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True">
    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#F7FFF9" />
        <SolidColorBrush x:Key="MutedBrush" Color="#99F7FFF9" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#66F7FFF9" />
        <SolidColorBrush x:Key="PanelBrush" Color="#A8090E0B" />
        <SolidColorBrush x:Key="PanelStrongBrush" Color="#D00A0F0C" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#28FFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#1ED760" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#39E878" />

        <Style TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="54" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#24FFFFFF" />
            <Setter Property="Background" Value="#18FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#26FFFFFF" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#38FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#12FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#061108" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#19C255" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Background" Value="#85000000" />
            <Setter Property="BorderBrush" Value="#24FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxChrome" Property="BorderBrush" Value="#661ED760" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="Root" Margin="10" MouseLeftButtonDown="OnDragWindow">
        <Border x:Name="SetupPanel"
                CornerRadius="8"
                Background="{StaticResource PanelStrongBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.36" Color="#000000" />
            </Border.Effect>
            <Grid VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="Spotify Lyrics" Margin="10,0,0,0" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                </StackPanel>
                <TextBlock Grid.Row="1"
                           Margin="0,8,0,0"
                           Text="Redirect URI: http://127.0.0.1:8766/callback"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="13" />
                <TextBox x:Name="ClientIdBox"
                         Grid.Row="2"
                         Margin="0,14,0,0" />
                <DockPanel Grid.Row="3" Margin="0,14,0,0">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Content="Connect" Width="98" Style="{StaticResource PrimaryButton}" Click="OnConnect" />
                        <Button Content="Quit" Width="72" Margin="8,0,0,0" Click="OnQuit" />
                    </StackPanel>
                    <TextBlock x:Name="SetupStatus"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                </DockPanel>
            </Grid>
        </Border>

        <Grid x:Name="LyricsPanel" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid x:Name="LyricsGrid" VerticalAlignment="Center" Margin="24,8,24,56">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border x:Name="CurrentLineClip" ClipToBounds="True" HorizontalAlignment="Stretch">
                        <TextBlock x:Name="CurrentLine"
                                   Text="Waiting for playback..."
                                   TextAlignment="Center"
                                   TextWrapping="NoWrap"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="38"
                                   FontWeight="ExtraBold"
                                   LineHeight="48"
                                   RenderTransformOrigin="0,0">
                            <TextBlock.RenderTransform>
                                <TranslateTransform />
                            </TextBlock.RenderTransform>
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="9" ShadowDepth="1" Opacity="0.95" Color="#000000" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </Border>
                    <Border x:Name="NextLineClip" Grid.Row="1" Margin="0,4,0,0" ClipToBounds="True" HorizontalAlignment="Stretch">
                        <TextBlock x:Name="NextLine"
                                   TextAlignment="Center"
                                   TextWrapping="NoWrap"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="23"
                                   FontWeight="SemiBold"
                                   LineHeight="30"
                                   RenderTransformOrigin="0,0">
                            <TextBlock.RenderTransform>
                                <TranslateTransform />
                            </TextBlock.RenderTransform>
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="7" ShadowDepth="1" Opacity="0.78" Color="#000000" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </Border>
                </Grid>

                <Border x:Name="Toolbar"
                        Grid.Row="1"
                        Height="48"
                        CornerRadius="8"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        Padding="10,7">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button x:Name="StyleButton" Content="Style" Width="58" Margin="0,0,7,0" Click="OnToggleStyle" />
                            <Button x:Name="LineModeButton" Content="2 lines" Width="68" Margin="0,0,7,0" Click="OnToggleLineMode" />
                            <Button x:Name="LockButton" Content="Lock" Width="58" Margin="0,0,7,0" Click="OnToggleLock" />
                            <Button Content="Disconnect" Width="92" Margin="0,0,7,0" Click="OnDisconnect" />
                            <Button Content="Quit" Width="58" Click="OnQuit" />
                        </StackPanel>
                        <Grid Margin="0,0,10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="26"
                                    Height="26"
                                    CornerRadius="13"
                                    Background="#1ED760"
                                    VerticalAlignment="Center">
                                <TextBlock Text="S"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#061108"
                                           FontWeight="Bold"
                                           FontSize="12" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="9,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="TrackTitle"
                                           Text="Waiting for Spotify"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="TrackArtist"
                                           Text="Play a song in Spotify."
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </DockPanel>
                </Border>

                <Border x:Name="StylePanel"
                        Visibility="Collapsed"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,54"
                        CornerRadius="8"
                        Background="{StaticResource PanelStrongBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        Padding="11,9">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Size" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Margin="0,0,8,0" />
                        <Slider x:Name="FontSlider" Width="124" Minimum="20" Maximum="56" ValueChanged="OnFontChanged" />
                        <TextBlock Text="Color" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Margin="14,0,8,0" />
                        <TextBox x:Name="ColorBox" Width="84" Height="30" TextChanged="OnColorChanged" />
                        <Button Content="Reset" Width="62" Margin="8,0,0,0" Click="OnResetStyle" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
